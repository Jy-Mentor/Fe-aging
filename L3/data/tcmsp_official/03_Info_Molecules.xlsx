<script>
(function(){
  const KEY='tcmsp_daily_popup_date';
  const today=new Date().toISOString().slice(0,10);
  if(localStorage.getItem(KEY)===today) return;

  // 主题色：优先读 <html data-dp-primary="#0b5bd3">，否则用站点<a>链接色，最后兜底蓝
  const htmlPrimary=document.documentElement.getAttribute('data-dp-primary');
  const anchor = document.querySelector('a');
  const primary = htmlPrimary || (anchor ? getComputedStyle(anchor).color : '#2b6cb0');

  const css=document.createElement('style');
  css.textContent = `
    :root{
      --dp-primary:${primary};
      --dp-radius:12px;
      --dp-border:#e5e7eb;
      --dp-text:#111827;
    }
    #dp{position:fixed;inset:0;z-index:9999;}
    #dp .b{position:absolute;inset:0;background:rgba(0,0,0,.28);}
    #dp .m{
      position:absolute; left:50%; top:10vh; transform:translateX(-50%);
      width:min(92vw,720px); max-height:80vh;
      display:grid; grid-template-rows:auto 1fr auto;
      background:#fff; color:var(--dp-text);
      border:1px solid var(--dp-border); border-radius:var(--dp-radius);
      box-shadow:0 12px 30px rgba(0,0,0,.12);
      opacity:0; transition:opacity .18s ease, transform .18s ease;
    }
    #dp.show .m{opacity:1;}
    #dp .head{padding:16px 20px; border-top:4px solid var(--dp-primary);}
    #dp .title{margin:0; font-size:20px; line-height:1.4; font-weight:600;}
    #dp .scroller{padding:0 20px 16px; overflow:auto;}
    #dp .ct{font-size:14px; line-height:1.75;}
    #dp .ct h3{margin:14px 0 6px; font-size:15px; color:#111;}
    #dp .ct p{margin:6px 0;}
    #dp .qrbox{
      margin:14px auto 0; padding:10px;
      border:1px dashed #d1d5db; border-radius:10px;
      max-width:280px; text-align:center;
    }
    #dp .qrbox img{display:block; width:100%; max-width:220px; height:auto; margin:0 auto;}
    #dp .qrbox .cap{margin-top:6px; font-size:12px; color:#6b7280;}
    #dc{
      margin:0 20px 16px; justify-self:end;
      display:inline-block; padding:10px 16px; font-size:14px;
      border-radius:10px; border:1px solid var(--dp-primary);
      background:var(--dp-primary); color:#fff; cursor:pointer;
    }
    #dc:active{transform:translateY(1px);}
    @media (max-width:480px){ #dc{width:calc(100% - 40px); justify-self:stretch; } }
  `;
  document.head.appendChild(css);

  const root=document.createElement('div');
  root.id='dp';
  root.innerHTML = `
    <div class="b" aria-hidden="true"></div>
    <div class="m" role="dialog" aria-modal="true" aria-labelledby="dt">
      <div class="head"><h2 id="dt" class="title">十年砺剑，助您破局 —— TCMSP 9.01 前沿技术与应用高级研修班 邀请函</h2></div>
      <div class="scroller">
        <div class="ct">
          <p>尊敬的教授/研究员：</p>
          <p>您好！为助力中医药科研工作者掌握网络药理学前沿技术，突破传统研究瓶颈，提升论文与基金竞争力，特举办“TCMSP 9.01 前沿技术与应用高级研修班”。诚邀拨冗出席。</p>

          <h3>一、组织单位</h3>
          <p><b>主办单位：</b>陕西秦岭七药协同创新中心有限公司</p>
          <p><b>协办单位：</b>西北大学、安徽中医药大学、西北工业大学、西安交通大学、西北农林科技大学、南京中医药大学</p>

          <h3>二、报名对象</h3>
          <p>面向全国开放，诚邀中医药相关领域硕博研究生、临床科研人员、高校教师、药企研发人员及科研管理者参加。</p>

          <h3>三、研讨时间与地点</h3>
          <p><b>时间：</b>2026年6月底</p>
          <p><b>地点1：</b>陕西中医药大学实践教学基地（杨凌工业园区高干渠路东段3号工业园区公共服务中心15层）</p>

          <h3>四、会议核心内容与重要性</h3>
          <p>聚焦复方多成分协同作用及复杂网络机制解析，课程以系统药理学理论与方法为核心主线，系统涵盖中药复方网络分析、系统药理学工具与软件应用、分子对接、分子动力学模拟、转录组学分析及虚拟基因敲除等关键技术模块，并结合典型课题设计与天然产物筛选案例，构建从机制挖掘到功能验证的完整研究路径。通过理论讲解与实操训练相结合，全面提升学员在机制解析、低成本验证、高水平论文发表及基金设计等方面的综合能力。</p>

          <div class="qrbox">
            <img src="/attachment/tcmsp-invite.png" alt="报名二维码" loading="lazy" decoding="async">
	    <div>扫码占位 → 立即领取独家预习资料包!</div>
	    <div>17392526548 (官方电话及微信）</div>
          </div>
        </div>
      </div>
      <button id="dc" type="button" aria-label="关闭弹窗">我知道了</button>
    </div>
  `;

  function mount(){
    document.body.appendChild(root);
    requestAnimationFrame(()=>root.classList.add('show'));
    // 只允许点按钮关闭；如需点遮罩也关闭，解除下一行注释
    // root.querySelector('.b').addEventListener('click', ()=>document.getElementById('dc').click());
    document.getElementById('dc').addEventListener('click', function(){
      try{ localStorage.setItem(KEY, today); }catch(e){}
      root.remove(); document.documentElement.style.overflow='';
    });
    document.documentElement.style.overflow='hidden';
  }
  if(document.body){ mount(); } else { document.addEventListener('DOMContentLoaded', mount, {once:true}); }
})();
</script>


